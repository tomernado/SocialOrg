// Prisma schema for AI News Aggregator
// DB: PostgreSQL (Supabase free tier)
// Run `npm run db:push` to sync schema to the database.
// Run `npm run db:generate` to regenerate the Prisma client.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id             String   @id @default(uuid()) @db.Uuid
  original_url   String   @unique
  title          String
  image_url      String?
  category       String
  sub_category   String
  tag            String
  relevance_score Int      @default(0)
  ai_summary     String   @db.Text
  created_at     DateTime @default(now())

  @@index([sub_category, created_at])
  @@map("articles")
}
