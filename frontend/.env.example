# Copy this file to frontend/.env for local development.
# In Vercel → Project Settings → Environment Variables, add the production value.
# Frontend env vars MUST be prefixed with VITE_ to be exposed to the browser.
# NEVER put API keys or secrets here — this file is safe to commit.

# ── Backend API URL ───────────────────────────────────────────────────────────
# Local dev:  http://localhost:3001
# Production: your Render backend URL (no trailing slash)
# Render URL: https://socialorg-d4z3.onrender.com
VITE_API_BASE_URL=http://localhost:3001
